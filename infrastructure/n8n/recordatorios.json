{
  "name": "Recordatorios - Auto No-Show",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 30 }]
        }
      },
      "id": "schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE appointments\nSET status = 'no_show', updated_at = NOW()\nWHERE status = 'scheduled'\n  AND deleted_at IS NULL\n  AND scheduled_at + (duration_minutes || ' minutes')::INTERVAL + INTERVAL '15 minutes' < NOW()\nRETURNING\n  id,\n  scheduled_at,\n  appointment_type,\n  (SELECT first_name || ' ' || last_name FROM patients WHERE id = patient_id) AS patient_name",
        "options": {}
      },
      "id": "pg-no-show",
      "name": "PG - Marcar No-Show",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [500, 300]
    },
    {
      "parameters": {
        "rule": {
          "conditions": {
            "conditions": [{ "id": "c1", "value1": "={{ $json.id }}", "operation": "isNotEmpty" }],
            "combinator": "and"
          },
          "options": {}
        },
        "options": {}
      },
      "id": "if-has-results",
      "name": "IF - Hay No-Shows",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [750, 300]
    },
    {
      "parameters": {
        "sendTo": "={{ $env.NOTIFICATION_EMAIL }}",
        "subject": "=⚠️ No-show registrado: {{ $json.patient_name }}",
        "emailType": "text",
        "message": "=Se marcó como no-show:\n\nPaciente: {{ $json.patient_name }}\nFecha: {{ $json.scheduled_at }}\nTipo: {{ $json.appointment_type }}\n\nID: {{ $json.id }}",
        "options": {}
      },
      "id": "gmail-notify",
      "name": "Gmail - Notificar No-Show",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [1000, 150]
    }
  ],
  "connections": {
    "Schedule Trigger": { "main": [[{ "node": "PG - Marcar No-Show", "type": "main" }]] },
    "PG - Marcar No-Show": { "main": [[{ "node": "IF - Hay No-Shows", "type": "main" }]] },
    "IF - Hay No-Shows": {
      "main": [
        [{ "node": "Gmail - Notificar No-Show", "type": "main" }],
        []
      ]
    }
  },
  "active": true,
  "settings": {},
  "id": "recordatorios"
}
